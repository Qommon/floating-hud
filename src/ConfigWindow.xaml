<Window x:Class="FloatingHud.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FloatingHud"
        Title="配置"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,10,18" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="92" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Style="{StaticResource FieldLabelStyle}"
                   Text="默认值"
                   ToolTip="命令暂未产生可用输出时显示的文本。" />
        <TextBox x:Name="DefaultTextInput"
                 Grid.Row="0"
                 Grid.Column="1"
                 Margin="0,0,0,18"
                 Text="{Binding DefaultText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Style="{StaticResource FieldLabelStyle}"
                   Text="命令行"
                   ToolTip="定时执行的命令，标准输出用于刷新 HUD 内容。" />
        <TextBox x:Name="CommandLineInput"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,0,0,10"
                 Width="360"
                 Height="96"
                 AcceptsReturn="True"
                 Text="{Binding CommandLine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Style="{StaticResource FieldLabelStyle}"
                   Text="刷新周期"
                   ToolTip="命令重复执行的间隔秒数；0 表示启动时只执行一次。" />
        <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,18">
            <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" VerticalAlignment="Center" Text="秒" />
            <TextBox x:Name="RefreshIntervalInput"
                     DataObject.Pasting="RefreshIntervalInput_Pasting"
                     PreviewTextInput="RefreshIntervalInput_PreviewTextInput"
                     Text="{Binding RefreshIntervalText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Style="{StaticResource FieldLabelStyle}"
                   Text="字号"
                   ToolTip="HUD 文本的逻辑字号，也会影响滚轮缩放后的持久化值。" />
        <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,18">
            <TextBlock x:Name="FontSizeValueText"
                       DockPanel.Dock="Right"
                       Width="48"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       TextAlignment="Right" />
            <Slider x:Name="FontSizeSlider"
                    Minimum="{x:Static local:HudLayoutLimits.MinFontSize}"
                    Maximum="{x:Static local:HudLayoutLimits.MaxFontSize}"
                    TickFrequency="0.1"
                    SmallChange="0.1"
                    LargeChange="1"
                    IsSnapToTickEnabled="False"
                    Value="{Binding FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ValueChanged="FontSizeSlider_ValueChanged" />
        </DockPanel>

        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Style="{StaticResource FieldLabelStyle}"
                   Text="锚点"
                   ToolTip="持久化坐标描述文本框内哪个相对位置，0 为左/上，1 为右/下。" />
        <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="36" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="36" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="56" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="水平" />
            <Slider x:Name="AnchorXSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="1"
                    TickFrequency="0.01"
                    SmallChange="0.01"
                    LargeChange="0.1"
                    IsSnapToTickEnabled="False"
                    Value="{Binding AnchorX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ValueChanged="AnchorSlider_ValueChanged" />
            <TextBox x:Name="AnchorXValueText"
                       Grid.Column="2"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       Text="{Binding AnchorXText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       TextChanged="AnchorInput_TextChanged" />
            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="垂直" />
            <Slider x:Name="AnchorYSlider"
                    Grid.Column="5"
                    Minimum="0"
                    Maximum="1"
                    TickFrequency="0.01"
                    SmallChange="0.01"
                    LargeChange="0.1"
                    IsSnapToTickEnabled="False"
                    Value="{Binding AnchorY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ValueChanged="AnchorSlider_ValueChanged" />
            <TextBox x:Name="AnchorYValueText"
                       Grid.Column="6"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       Text="{Binding AnchorYText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       TextChanged="AnchorInput_TextChanged" />
        </Grid>

        <TextBlock Grid.Row="5"
                   Grid.Column="0"
                   Style="{StaticResource FieldLabelStyle}"
                   Text="悬停背景"
                   ToolTip="鼠标悬停在 HUD 文本区域时显示的背景色。" />
        <Grid Grid.Row="5" Grid.Column="1" Height="20" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="94" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="颜色" />
            <Border x:Name="HoverBackgroundColorPreview"
                    Grid.Column="1"
                    Width="18"
                    Height="12"
                    Cursor="Hand"
                    MouseLeftButtonDown="HoverBackgroundColorPreview_MouseLeftButtonDown" />
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="不透明度" />
            <Slider x:Name="HoverBackgroundAlphaSlider"
                    Grid.Column="4"
                    Height="20"
                    Minimum="0"
                    Maximum="255"
                    TickFrequency="1"
                    SmallChange="1"
                    LargeChange="16"
                    IsSnapToTickEnabled="True"
                    ValueChanged="ColorAlphaSlider_ValueChanged" />
            <TextBox x:Name="HoverBackgroundColorInput"
                     Grid.Column="6"
                     Height="20"
                     VerticalContentAlignment="Center"
                     Text="{Binding HoverBackgroundColorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="ColorInput_TextChanged" />
        </Grid>

        <TextBlock Grid.Row="6"
                   Grid.Column="0"
                   Style="{StaticResource FieldLabelStyle}"
                   Text="锁定外框"
                   ToolTip="HUD 锁定且鼠标悬停时显示的外框颜色。" />
        <Grid Grid.Row="6" Grid.Column="1" Height="20" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="94" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="颜色" />
            <Border x:Name="LockedBorderColorPreview"
                    Grid.Column="1"
                    Width="18"
                    Height="12"
                    Cursor="Hand"
                    MouseLeftButtonDown="LockedBorderColorPreview_MouseLeftButtonDown" />
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="不透明度" />
            <Slider x:Name="LockedBorderAlphaSlider"
                    Grid.Column="4"
                    Height="20"
                    Minimum="0"
                    Maximum="255"
                    TickFrequency="1"
                    SmallChange="1"
                    LargeChange="16"
                    IsSnapToTickEnabled="True"
                    ValueChanged="ColorAlphaSlider_ValueChanged" />
            <TextBox x:Name="LockedBorderColorInput"
                     Grid.Column="6"
                     Height="20"
                     VerticalContentAlignment="Center"
                     Text="{Binding LockedBorderColorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="ColorInput_TextChanged" />
        </Grid>

        <TextBlock Grid.Row="7"
                   Grid.Column="0"
                   Style="{StaticResource FieldLabelStyle}"
                   Text="错误外框"
                   ToolTip="命令行输出非法或执行超时时显示的错误外框颜色。" />
        <Grid Grid.Row="7" Grid.Column="1" Height="20" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="94" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="颜色" />
            <Border x:Name="ErrorBorderColorPreview"
                    Grid.Column="1"
                    Width="18"
                    Height="12"
                    Cursor="Hand"
                    MouseLeftButtonDown="ErrorBorderColorPreview_MouseLeftButtonDown" />
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="不透明度" />
            <Slider x:Name="ErrorBorderAlphaSlider"
                    Grid.Column="4"
                    Height="20"
                    Minimum="0"
                    Maximum="255"
                    TickFrequency="1"
                    SmallChange="1"
                    LargeChange="16"
                    IsSnapToTickEnabled="True"
                    ValueChanged="ColorAlphaSlider_ValueChanged" />
            <TextBox x:Name="ErrorBorderColorInput"
                     Grid.Column="6"
                     Height="20"
                     VerticalContentAlignment="Center"
                     Text="{Binding ErrorBorderColorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="ColorInput_TextChanged" />
        </Grid>

        <TextBlock Grid.Row="8"
                   Grid.Column="0"
                   Style="{StaticResource FieldLabelStyle}"
                   Text="警告外框"
                   ToolTip="标准输出合法但命令退出码非零时显示的外框颜色。" />
        <Grid Grid.Row="8" Grid.Column="1" Height="20" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="94" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="颜色" />
            <Border x:Name="WarningBorderColorPreview"
                    Grid.Column="1"
                    Width="18"
                    Height="12"
                    Cursor="Hand"
                    MouseLeftButtonDown="WarningBorderColorPreview_MouseLeftButtonDown" />
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="不透明度" />
            <Slider x:Name="WarningBorderAlphaSlider"
                    Grid.Column="4"
                    Height="20"
                    Minimum="0"
                    Maximum="255"
                    TickFrequency="1"
                    SmallChange="1"
                    LargeChange="16"
                    IsSnapToTickEnabled="True"
                    ValueChanged="ColorAlphaSlider_ValueChanged" />
            <TextBox x:Name="WarningBorderColorInput"
                     Grid.Column="6"
                     Height="20"
                     VerticalContentAlignment="Center"
                     Text="{Binding WarningBorderColorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="ColorInput_TextChanged" />
        </Grid>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button IsDefault="True" MinWidth="76" Margin="0,0,8,0" Click="OkButton_Click" Content="确定" />
            <Button IsCancel="True" MinWidth="76" Content="取消" />
        </StackPanel>
    </Grid>
</Window>
